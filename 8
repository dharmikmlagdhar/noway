<!DOCTYPE html>
<html>
<head>
    <title>Calculator</title>
</head>
<body>

<script>

var a=10;
var b=5;
var op='+';

switch(op)
{
    case '+':
        document.write(a+b);
        break;

    case '-':
        document.write(a-b);
        break;

    case '*':
        document.write(a*b);
        break;

    case '/':
        document.write(a/b);
        break;

    default:
        document.write("Invalid Operator");
}

</script>

</body>
</html>
